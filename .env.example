# HelixOS local development environment
# Copy to apps/web/.env.local for browser dev (setup-dev.sh does this automatically)

# Web -> API (browser dev stack on port 8000)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_TOKEN=org-demo-token

# API sidecar / standalone API
HELIX_DATABASE_URL=sqlite:///<repo-root>/.data/helixos-dev.db
HELIX_AI_PROVIDER=stub
# HELIX_AI_PROVIDER=openai
# HELIX_OPENAI_API_KEY=sk-...

# Desktop
HELIX_DISABLE_AUTOUPDATE=1
# HELIX_PYTHON=/path/to/python3

# Optional Postgres (docker compose up -d postgres)
# HELIX_DATABASE_URL=postgresql+psycopg://helixos:helixos@127.0.0.1:5432/helixos
