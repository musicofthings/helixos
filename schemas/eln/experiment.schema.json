{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helixos.dev/schemas/eln/experiment.schema.json",
  "title": "Experiment",
  "type": "object",
  "required": ["id", "organization_id", "title", "status", "blocks", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "organization_id": { "type": "string" },
    "project_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "in_review", "signed", "amended", "archived"]
    },
    "blocks": {
      "type": "array",
      "items": { "$ref": "#/$defs/block" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "block": {
      "type": "object",
      "required": ["type", "content"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["text", "table", "protocol_steps", "reagent_list", "sequence", "image", "chart", "ai_annotation"]
        },
        "content": {}
      }
    }
  }
}
